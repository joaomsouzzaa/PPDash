# Chave da Anthropic (geração do EDL com claude-opus-4-8)
ANTHROPIC_API_KEY=sk-ant-...

# Chave da ElevenLabs (transcrição do video-use)
ELEVENLABS_API_KEY=...

# Supabase do PPDash (service role — atualiza video_jobs e sobe o resultado)
SUPABASE_URL=https://wxxhsuprddzprnrwovwi.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...

# Caminho do repo browser-use/video-use já instalado (uv sync) com FFmpeg disponível
VIDEO_USE_DIR=./video-use

# Pasta onde os vídeos cortados são gravados e servidos em /files/<job>.mp4
OUTPUT_DIR=/data/outputs

# Pasta de trabalho por job (vídeo cortado + assets), servida em /work/<job> para o Remotion
WORK_DIR=/data/work

# Base pública do serviço (usada para montar a URL do resultado)
PUBLIC_BASE=https://srv1779748.hstgr.cloud

# Base http interna usada pelo render do Remotion (mesmo host) para carregar as mídias
INTERNAL_BASE=http://127.0.0.1:8080

# Modelo do faster-whisper (legendas word-level). small = bom equilíbrio em CPU.
WHISPER_MODEL=small
